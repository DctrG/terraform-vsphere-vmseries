vsphere_server = "vcenter.example.local"
vsphere_user   = "administrator@vsphere.local"
vsphere_password = "CHANGE_ME"

name           = "pa-vmseries-01"
datacenter     = "DC1"
cluster_name   = "Cluster01"
host_name      = "esxi-01.example.local"
datastore_name = "vsanDatastore"
folder         = "Network/Security"

# Set exactly one image source.
#
# Recommended for repeated deployments: clone an already-imported golden
# VM/template so Terraform does not import the large OVA on every VM create.
ova_source_image_name = "templates/PA-VM-Series-Golden"
# ova_source_image_uuid = "422b..."
# ova_source_image_folder = "templates"
#
# vCenter clone is the default. For standalone ESXi, copy the golden VMDK on
# the datastore with vmkfstools over SSH and attach that per-VM disk copy.
# ova_source_image_clone_type = "esxi"
# ova_source_image_vmdk_path  = "/vmfs/volumes/datastore1/PA-VM-Series-Golden/PA-VM-Series-Golden.vmdk"
# esxi_ssh_host              = "192.0.2.10"
# esxi_ssh_user              = "root"
# esxi_ssh_private_key       = file("/secure/keys/esxi_id_rsa")
#
# First-time import only: use an OVA path or URL to create the golden image.
# Reusing these for every firewall will run the OVF/OVA import every time.
# ova_local_path = "/opt/images/PA-VM-ESX.ova"
# ova_remote_url = "https://example.local/images/PA-VM-ESX.ova"

# Use host_system_id instead of host_name if your automation already resolves
# the ESXi managed object ID.
# host_name      = null
# host_system_id = "host-123"

# For a standalone ESXi host, omit cluster_name and use a resource pool instead.
# datacenter         = "ha-datacenter"
# cluster_name       = null
# resource_pool_name = "Resources"

network_interfaces = [
  { ovf_label = "VM Network", ovf_mapping = "Ethernet 1", network_name = "PG-MGMT" },
  { ovf_label = "VM Network", ovf_mapping = "Ethernet 2", network_name = "PG-UNTRUST" },
  { ovf_label = "VM Network", ovf_mapping = "Ethernet 3", network_name = "PG-TRUST" }
]

mgmt_type            = "static"
mgmt_ip_address      = "10.10.10.51"
mgmt_default_gateway = "10.10.10.1"
mgmt_netmask         = "255.255.255.0"
dns_primary          = "10.10.10.10"
dns_secondary        = "10.10.10.11"

# For DHCP management, set mgmt_type and omit the static address fields.
# mgmt_type            = "dhcp-client"
# mgmt_ip_address      = null
# mgmt_default_gateway = null
# mgmt_netmask         = null

# Use the Panorama address reachable from the firewall management interface.
# If Panorama is behind NAT, this is usually the public IP or DNS name, even if
# request plugins sw_fw_license bootstrap-parameters prints a private address.
panorama_server = "panorama.example.com"
template_stack  = "TS-VMWARE"
device_group    = "DG-VMWARE"

# For Software Firewall License plugin onboarding, use the auth-key returned by
# request plugins sw_fw_license bootstrap-parameters. This renders auth-key in
# /config/init-cfg.txt.
bootstrap_auth_key           = "CHANGE_ME"
bootstrap_plugin_op_commands = "panorama-licensing-mode-on"

# Optional: set only when your workflow explicitly returns/requires these keys.
# bootstrap_vm_auth_key            = "CHANGE_ME"
# bootstrap_registration_pin_id    = "CHANGE_ME"
# bootstrap_registration_pin_value = "CHANGE_ME"
# bootstrap_license_authcodes      = "AUTHCODE1\nAUTHCODE2\n"

# VM-Series OVAs that expose guestinfo.pa_vm.* OVF properties can receive
# bootstrap values through vApp properties in addition to the bootstrap ISO.
# bootstrap_vapp_properties_enabled = true
# bootstrap_vapp_options            = null
# vapp_properties = {
#   "guestinfo.pa_vm.options" = "CHANGE_ME"
# }

# Optional: include additional files in the generated bootstrap ISO.
# bootstrap_files = {
#   "content/README.txt" = {
#     content = "Place PAN-OS content files under content/ when required.\n"
#   }
#   "plugins/plugin-package.tgz" = {
#     source = "/secure/artifacts/plugin-package.tgz"
#   }
# }
